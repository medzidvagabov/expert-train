}

body.dark .schedule-cell.type-lecture {
  background: #1E3A5F;
}

body.dark .schedule-cell.type-practice {
  background: #064E3B;
}

body.dark .schedule-cell.type-lab {
  background: #78350F;
}

body.dark .border-gray-100,
body.dark .dark\:border-gray-700 {
  border-color: #334155;
}

body.dark .hover\:bg-gray-100:hover,
body.dark .dark\:hover\:bg-gray-700:hover {
  background: #1E293B;
}

body.dark .bg-white\/80 {
  background: rgba(30, 41, 59, 0.8);
}

body.dark .bg-gray-900\/80 {
  background: rgba(15, 23, 42, 0.8);
}

body.dark .border-gray-100,
body.dark .dark\:border-gray-700 {
  border-color: #334155;
}

body.dark .bg-orange-50 {
  background: rgba(120, 53, 15, 0.2);
}

body.dark .bg-red-50 {
  background: rgba(127, 29, 29, 0.2);
}

body.dark .bg-blue-50 {
  background: rgba(30, 58, 95, 0.5);
}

body.dark .bg-green-50 {
  background: rgba(6, 78, 59, 0.2);
}

/* ============================================
   АДАПТИВНОСТЬ
   ============================================ */
@media (max-width: 1023px) {
  .sidebar {
    transform: translateX(-100%);
    z-index: 50;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.1);
  }

  .sidebar.open {
    transform: translateX(0);
  }

  .sidebar.collapsed {
    transform: translateX(-100%);
  }

  .main-content {
    margin-left: 0 !important;
  }
}